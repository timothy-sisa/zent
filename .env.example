# Example environment variables for zent-backend
# Copy this file to .env and fill in actual values

# MongoDB connection string (replace <username>, <password>, <dbname>)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.vyklmku.mongodb.net/<dbname>?appName=Cluster0

# Session secret - use a long random string in production
SESSION_SECRET=session_secret_here

# Port for the server to listen on
PORT=3000

# Node environment
env=development
